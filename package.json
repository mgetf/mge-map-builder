{
	"name": "mge-map-builder",
	"version": "0.1.0",
	"type": "module",
	"description": "Build custom TF2 MGE maps from prefab arenas",
	"scripts": {
		"start": "vite build && electrobun dev",
		"dev": "electrobun dev --watch",
		"dev:hmr": "concurrently \"bun run hmr\" \"bun run start\"",
		"hmr": "vite --port 5173",
		"build:canary": "vite build && electrobun build --env=canary"
	},
	"dependencies": {
		"clsx": "^2.1.1",
		"electrobun": "1.16.0",
		"tailwind-merge": "^3.5.0"
	},
	"devDependencies": {
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@tailwindcss/forms": "^0.5.11",
		"@tailwindcss/typography": "^0.5.19",
		"@tailwindcss/vite": "^4.2.2",
		"bits-ui": "^2.16.4",
		"concurrently": "^9.2.1",
		"svelte": "^5.55.0",
		"tailwind-variants": "^3.2.2",
		"tailwindcss": "^4.2.2",
		"typescript": "^6.0.2",
		"vite": "^8.0.3"
	}
}
